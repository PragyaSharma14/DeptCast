generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  member
  viewer
}

model User {
  id                    String        @id @default(uuid())
  name                  String
  email                 String        @unique
  passwordHash          String
  currentOrganizationId String?
  currentOrganization   Organization? @relation(fields: [currentOrganizationId], references: [id])
  createdAt             DateTime      @default(now())

  projects              Project[]
  memberships           Membership[]
}

model Organization {
  id                 String       @id @default(uuid())
  name               String
  logoUrl            String?
  tagline            String?
  description        String?      @db.Text
  
  // Details
  industry           String?
  companySize        String?
  website            String?
  brandColor         String?      @default("#aa3bff")
  
  // Contact
  contactEmail       String?
  contactPhone       String?
  address            String?
  country            String?
  state              String?
  city               String?

  subscriptionStatus String       @default("trialing")
  createdAt          DateTime     @default(now())

  users              User[]       // users who have this as currentOrganization
  projects           Project[]
  memberships        Membership[]
  invitations        Invitation[]
  schedules          CommunicationSchedule[]
  analytics          AnalyticsSnapshot?
}

model Project {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  templateId     String?
  template       Template?    @relation(fields: [templateId], references: [id])
  intent         String
  domain         String
  style          String
  avatar         String?
  voice          String?
  dimension      String?
  targetDuration Int          @default(8)
  status         String       @default("draft")
  finalVideoUrl  String?
  createdAt      DateTime     @default(now())

  scenes         Scene[]
  schedules      CommunicationSchedule[]
}

model Sector {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. "healthcare-pharma"
  name      String
  color     String?
  createdAt DateTime @default(now())

  departments SectorDepartment[]
}

model SectorDepartment {
  sectorId     String
  departmentId String
  sector       Sector     @relation(fields: [sectorId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])

  @@id([sectorId, departmentId])
}

model Department {
  id          String     @id @default(uuid())
  key         String     @unique // e.g. "hr", "it-support"
  name        String
  description String?
  icon        String?
  color       String?
  bg          String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  templates   Template[]
  sectors     SectorDepartment[]
}

model Template {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  key          String     // e.g. "leave-policy"
  title        String
  systemPrompt String     @db.Text
  keyPoints    String     @db.Text // Store as JSON string or comma separated
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  projects     Project[]
}

model Scene {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  sceneNumber Int
  description String   @db.Text
  prompt      String   @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @default(member)
  tokenHash      String
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  role           Role         @default(member)
  joinedAt       DateTime     @default(now())

  @@unique([userId, organizationId])
}

model CommunicationSchedule {
  id             String       @id @default(uuid())
  title          String
  scheduledAt    DateTime
  status         String       @default("scheduled") // scheduled, sent, missed
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  createdAt      DateTime     @default(now())
}

model AnalyticsSnapshot {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  totalReach     Int          @default(0)
  engagementRate Float        @default(0.0)
  totalVideos    Int          @default(0)
  activeUsers    Int          @default(0)
  updatedAt      DateTime     @updatedAt
}
